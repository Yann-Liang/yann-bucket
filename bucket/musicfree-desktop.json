{
    "version": "0.0.8",
    "description": "插件化、定制化、无广告的免费音乐播放器",
    "homepage": "https://github.com/maotoumao/MusicFreeDesktop",
    "license": "AGPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/maotoumao/MusicFreeDesktop/releases/download/v0.0.8/MusicFree-0.0.8-win32-x64-portable.zip",
            "hash": "sha256:b84ef7feced17a95dd704db9968867726008d782619d511656e5ece059951399",
            "extract_dir": "tmp_unpack"
        }
    },
    "pre_install": [
        "# 结束可能正在运行的旧程序",
        "Stop-Process -Name MusicFreeDesktop -Force -ErrorAction SilentlyContinue",
        "# 删除根目录下除 tmp_unpack 以外的所有旧文件/目录（避免后续覆盖冲突）",
        "Get-ChildItem -Path \"$dir\" -Exclude \"tmp_unpack\" | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue",
        "# 此时 $dir\\tmp_unpack 下应该有一个 MusicFree-$version-win32-x64-portable.zip",
        "$innerZip = \"$dir\\tmp_unpack\\MusicFree-$version-win32-x64-portable.zip\"",
        "# 使用 7z 解压内层 zip 到根目录（-aoa 强制覆盖）",
        "7z x \"$innerZip\" -o\"$dir\" -aoa -y",
        "# 删除 tmp_unpack 目录",
        "Remove-Item \"$dir\\tmp_unpack\" -Recurse -Force",
        "# 如果解压后出现同名文件夹，将其内容上移到根目录",
        "if (Test-Path \"$dir\\MusicFree-$version-win32-x64-portable\") {",
        "    Get-ChildItem \"$dir\\MusicFree-$version-win32-x64-portable\" | Move-Item -Destination \"$dir\" -Force",
        "    Remove-Item \"$dir\\MusicFree-$version-win32-x64-portable\" -Force",
        "}"
    ],
    "shortcuts": [
        [
            "MusicFree.exe",
            "MusicFree"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/maotoumao/MusicFreeDesktop/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/maotoumao/MusicFreeDesktop/releases/download/v$version/MusicFreeDesktop-$version-win32-x64-portable.zip",
                "extract_dir": "tmp_unpack"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
